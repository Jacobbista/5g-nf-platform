diff --git a/src/smf/session-info.c b/src/smf/session-info.c
new file mode 100644
index 0000000..6264fec
--- /dev/null
+++ b/src/smf/session-info.c
@@ -0,0 +1,77 @@
+#include "ogs-app.h"
+#include "context.h"
+#include "session-info.h"
+#include "sbi/openapi/model/up_cnx_state.h"
+
+static char *session_info_handler(const char *url)
+{
+    smf_ue_t *smf_ue = NULL;
+    smf_sess_t *sess = NULL;
+    char *out = NULL;
+    char *entries = NULL;
+    char *tmp = NULL;
+    bool first = true;
+
+    if (strcmp(url, "/session-info") != 0)
+        return NULL;
+
+    entries = ogs_strdup("");
+
+    ogs_list_for_each(&smf_self()->smf_ue_list, smf_ue) {
+        const char *imsi = smf_ue->supi;
+        if (imsi && strncmp(imsi, "imsi-", 5) == 0)
+            imsi += 5;
+        else if (!imsi)
+            imsi = "";
+
+        ogs_list_for_each(&smf_ue->sess_list, sess) {
+            char *ipv4 = NULL;
+            char *ipv6 = NULL;
+            char *sd_str = NULL;
+            const char *up_state = NULL;
+
+            if (sess->ipv4)
+                ipv4 = ogs_ipv4_to_string(sess->ipv4->addr[0]);
+            if (sess->ipv6)
+                ipv6 = ogs_ipv6addr_to_string((uint8_t *)sess->ipv6->addr);
+            sd_str = ogs_s_nssai_sd_to_string(sess->s_nssai.sd);
+            up_state = OpenAPI_up_cnx_state_ToString(sess->up_cnx_state);
+
+            tmp = ogs_msprintf(
+                "%s%s{"
+                "\"imsi\":\"%s\","
+                "\"dnn\":\"%s\","
+                "\"ipv4\":\"%s\","
+                "\"ipv6\":\"%s\","
+                "\"snssai\":{\"sst\":%d,\"sd\":\"%s\"},"
+                "\"up_cnx_state\":\"%s\""
+                "}",
+                entries,
+                first ? "" : ",",
+                imsi,
+                sess->session.name ? sess->session.name : "",
+                ipv4 ? ipv4 : "",
+                ipv6 ? ipv6 : "",
+                (int)sess->s_nssai.sst,
+                sd_str ? sd_str : "",
+                up_state ? up_state : "");
+
+            ogs_free(entries);
+            entries = tmp;
+            first = false;
+
+            if (ipv4) ogs_free(ipv4);
+            if (ipv6) ogs_free(ipv6);
+            if (sd_str) ogs_free(sd_str);
+        }
+    }
+
+    out = ogs_msprintf("{\"sessions\":[%s]}", entries);
+    ogs_free(entries);
+    return out;
+}
+
+void smf_session_info_handler_register(void)
+{
+    ogs_metrics_set_custom_url_handler(session_info_handler);
+}
